# X API (OAuth 1.0a user context — required to POST)
# Get these from developer.x.com -> your app -> Keys and tokens.
# The access token/secret must be generated with READ AND WRITE permission.
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# Set to 1 to print tweets instead of posting them.
DRY_RUN=1
